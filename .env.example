# ─────────────────────────────────────────────────────────────
# Noteworthy — environment variables
#
# Copy this file to `.env.local` and fill in the values.
#   • Local dev  → local Supabase Docker stack (`npx supabase start`);
#                  get the key values from `npx supabase status`.
#   • Deployed   → hosted Supabase project; values are set in Vercel
#                  (Production + Preview), never committed.
# See README.md (port map) and CONTRIBUTING.md.
# ─────────────────────────────────────────────────────────────

# Supabase API URL.
#   Local:  http://127.0.0.1:54331   (offset-port local stack)
#   Hosted: https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331

# Modern publishable key (sb_publishable_...). Safe to expose to the browser;
# access is enforced by RLS. Legacy fallback: NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key

# Modern secret key (sb_secret_...). SERVER ONLY — full admin access, bypasses
# RLS. Never prefix with NEXT_PUBLIC_. Used by the account-deletion route.
# Legacy fallback: SUPABASE_SERVICE_ROLE_KEY.
SUPABASE_SECRET_KEY=sb_secret_your-key

# Secret used to sign vault / bin-reveal cookies (Hidden privacy vault).
# Any long random string — generate with:  openssl rand -hex 32
VAULT_COOKIE_SECRET=generate-a-64-char-hex-string
